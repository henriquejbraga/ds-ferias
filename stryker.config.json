{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts",
    "related": false
  },
  "tempDirName": "stryker-tmp",
  "inPlace": true,
  "mutate": [
    "lib/**/*.ts",
    "services/**/*.ts",
    "repositories/**/*.ts"
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/generated/**",
    "**/*.test.ts",
    "lib/prisma.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 80,
    "break": 80
  },
  "coverageAnalysis": "perTest",
  "reporters": ["clear-text", "html", "progress"]
}
