// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// HIERARQUIA DE CARGOS
// ============================================================
enum Role {
  COLABORADOR
  GESTOR
  FUNCIONARIO
  COORDENADOR
  GERENTE
  DIRETOR
  RH
}

// ============================================================
// STATUS DO CICLO DE APROVAÇÃO
// ============================================================
enum VacationStatus {
  PENDENTE
  APROVADO_GESTOR
  APROVADO_COORDENADOR
  APROVADO_GERENTE
  APROVADO_DIRETOR
  APROVADO_RH
  REPROVADO
  CANCELADO
}

enum FeedbackType {
  BUG
  SUGGESTION
  ELOGIO
  OUTRO
}

enum FeedbackStatus {
  PENDENTE
  RESOLVIDO
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  avatarUrl    String?
  passwordHash String
  role         Role
  registration String   @unique
  department   String?
  hireDate     DateTime?
  team         String?   @map("time")

  feedbacks        Feedback[]
  vacationRequests VacationRequest[]
  historyEntries   VacationRequestHistory[] @relation("HistoryChangedByUser")
  blackoutPeriods  BlackoutPeriod[]
  acquisitionPeriods AcquisitionPeriod[]

  managerId String?
  manager   User?   @relation("ManagerReports", fields: [managerId], references: [id])
  reports   User[]  @relation("ManagerReports")

  mustChangePassword Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId])
  @@index([role, name])
  @@index([team])
}

model Feedback {
  id        String       @id @default(cuid())
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
  type      FeedbackType
  status    FeedbackStatus @default(PENDENTE)
  message   String       @db.Text

  anonymousName String?
  
  createdAt DateTime     @default(now())
  // Adicionado default(now()) para permitir sincronização com dados existentes
  updatedAt DateTime     @default(now()) @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
}

model VacationRequest {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  acquisitionPeriodId String?
  acquisitionPeriod   AcquisitionPeriod? @relation(fields: [acquisitionPeriodId], references: [id])
  startDate DateTime
  endDate   DateTime
  abono      Boolean        @default(false)
  thirteenth Boolean        @default(false)
  status      VacationStatus @default(PENDENTE)
  notes       String?        @db.Text
  managerNote String?        @db.Text
  hrNote      String?        @db.Text
  history VacationRequestHistory[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([acquisitionPeriodId])
}

model VacationRequestHistory {
  id                String         @id @default(cuid())
  vacationRequestId String
  vacationRequest   VacationRequest @relation(fields: [vacationRequestId], references: [id], onDelete: Cascade)
  previousStatus VacationStatus
  newStatus      VacationStatus
  changedByUserId String
  changedByUser   User           @relation("HistoryChangedByUser", fields: [changedByUserId], references: [id])
  note      String?   @db.Text
  changedAt DateTime  @default(now())
}

model BlackoutPeriod {
  id          String    @id @default(cuid())
  startDate   DateTime
  endDate     DateTime
  reason      String
  department  String?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
}

model AcquisitionPeriod {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  startDate DateTime
  endDate   DateTime
  accruedDays     Int
  usedDays        Int @default(0)
  manualUsedDays  Int @default(0)
  isManual        Boolean @default(false)
  unjustifiedAbsences Int @default(0)
  vacationRequests VacationRequest[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
  @@index([startDate, endDate])
}
