{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts",
    "related": false
  },
  "tempDirName": "stryker-tmp",
  "inPlace": true,
  "mutate": [
    "lib/**/*.ts",
    "services/**/*.ts",
    "repositories/**/*.ts"
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/generated/**",
    "**/*.test.ts",
    "lib/prisma.ts"
  ],
  "thresholds": {
    "high": 85,
    "low": 85,
    "break": 85
  },
  "coverageAnalysis": "perTest",
  "timeoutMS": 15000,
  "timeoutFactor": 4,
  "reporters": [
    "clear-text",
    "html",
    "progress"
  ]
}